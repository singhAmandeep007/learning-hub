@product = ecomm
@baseUrl = http://localhost:8000/api/v1/{{product}}/resources

###
# Get all resources (default pagination)
GET {{baseUrl}}/ HTTP/1.1

###
# Get all types (explicit)
GET {{baseUrl}}?type=all HTTP/1.1

###
# With custom page size
GET {{baseUrl}}?limit=10 HTTP/1.1

###
# Type filtering
# Get only videos
GET {{baseUrl}}?type=video HTTP/1.1

###
# Get only PDFs
GET {{baseUrl}}?type=pdf HTTP/1.1

###
# Get only articles
GET {{baseUrl}}?type=article HTTP/1.1

###
# Tag filtering
# Single tag
GET {{baseUrl}}?tags=buying%20guide HTTP/1.1

###
# Multiple tags (OR condition)
GET {{baseUrl}}?tags=buying%20guide,product%20comparison,recommendations HTTP/1.1

###
# URL encoded for special characters
GET {{baseUrl}}?tags=best%20sellers,new%20arrivals HTTP/1.1

###
# Search functionality
# Search in title and description
GET {{baseUrl}}?search=buying%20guide HTTP/1.1

###
# URL encoded search
GET {{baseUrl}}?search=product%20comparison HTTP/1.1

###
# Search with special characters
GET {{baseUrl}}?search=returns%20%26%20warranty HTTP/1.1

###
# Combined filters
# Type + Tags + Search
GET {{baseUrl}}?type=video&tags=tutorial,demo&search=comparison&limit=5 HTTP/1.1

###
# All filters with pagination
GET {{baseUrl}}?type=pdf&tags=reference,manual&search=guide&limit=10&cursor=20 HTTP/1.1

###
# Pagination Examples
# First page
GET {{baseUrl}}?limit=5 HTTP/1.1

###
# Second page (using cursor from first response)
GET {{baseUrl}}?limit=5&cursor=5 HTTP/1.1

###
# Third page
GET {{baseUrl}}?limit=5&cursor=10 HTTP/1.1


# GET Eg.
# curl -X GET "http://localhost:8000/api/v1/{{product}}/resources"

# POST Eg.
# file required in case video or pdf
# url required in case article
# thumbnail optional
# thumbnailUrl optional

# curl -X POST "http://localhost:8000/api/v1/{{product}}/resources" \
# 	-F "title=Laptop Buying Guide" \
# 	-F "description=Detailed guide for selecting a laptop by budget and usage" \
# 	-F "tags=buying guide,comparison,best sellers" \
# 	-F "type=article" \
# 	-F "url=https://example-store.com/blog/laptop-buying-guide" \
# 	-F "thumbnailUrl=https://cdn.example-store.com/images/laptop-guide-cover.jpg" \
# 	-F "file=@./pdfs/ecommerce_catalog.pdf" \
# 	-F "thumbnail=@./images/ecommerce_product.webp"

# PATCH Eg.
# curl -X PATCH "http://localhost:8000/api/v1/{{product}}/resources/6Ihi4wRZwra7iBJVXceF" \
#   -F "title=Post updated" \
# 	-F "description=Updated product comparison notes" \
# 	-F "tags=comparison,recommendations,premium picks" \
# 	-F "url=https://example-store.com/blog/product-comparison" \
# 	-F "thumbnail=@./images/ecommerce_product.webp" \
# 	-F "type=pdf" \
# 	-F "file=@./pdfs/ecommerce_simple.pdf"

# DELETE Eg.
# curl -X DELETE "http://localhost:8000/api/v1/{{product}}/resources/6Ihi4wRZwra7iBJVXceF"

