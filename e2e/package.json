{
  "name": "learning-hub-e2e",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "test": "playwright test",
    "test:headed": "playwright test --headed",
    "test:debug": "playwright test --debug",
    "test:ci": "CI=true E2E_RETRIES=0 E2E_MAX_FAILURES=1 playwright test --max-failures=1",
    "report": "playwright show-report result/playwright-report",
    "install:browsers": "playwright install --with-deps"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/node": "^24.7.2",
    "zod": "^4.1.11"
  }
}
